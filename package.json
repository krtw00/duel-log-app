{
  "name": "duel-log-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @duel-log/web --filter @duel-log/api --parallel dev",
    "auth:migrate-password-hashes": "node scripts/migrate-supabase-password-hashes.mjs",
    "db:start": "docker compose up -d db",
    "db:stop": "docker compose stop db",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:seed": "node scripts/db-seed.mjs",
    "db:reset": "node scripts/db-reset.mjs",
    "staging:build": "pnpm firebase:env:staging && pnpm --filter @duel-log/shared build && pnpm --filter @duel-log/web build",
    "build": "pnpm -r build",
    "cloudrun:env": "node scripts/generate-cloudrun-api-env.mjs",
    "cloudrun:build-api": "pnpm --filter @duel-log/shared build && pnpm --filter @duel-log/api build",
    "cloudrun:deploy-api": "bash scripts/deploy-cloudrun-api.sh",
    "firebase:env": "node scripts/generate-firebase-hosting-env.mjs",
    "firebase:env:staging": "node scripts/generate-firebase-hosting-env.mjs --input .env/staging --output .firebase/hosting.staging.env --api-base-url https://duel-log-api-staging.codenica.dev/api --primary-web-url https://duel-log-staging.web.app --legacy-web-hosts ''",
    "firebase:deploy:web": "bash scripts/deploy-firebase-hosting.sh",
    "firebase:deploy:web:staging": "FIREBASE_WEB_ENV_INPUT=${FIREBASE_WEB_ENV_INPUT:-.env/staging} FIREBASE_WEB_ENV_FILE=${FIREBASE_WEB_ENV_FILE:-.firebase/hosting.staging.env} FIREBASE_HOSTING_SITE=${FIREBASE_HOSTING_SITE:-duel-log-staging} FIREBASE_WEB_PRIMARY_URL=${FIREBASE_WEB_PRIMARY_URL:-https://duel-log-staging.web.app} FIREBASE_WEB_API_BASE_URL=${FIREBASE_WEB_API_BASE_URL:-https://duel-log-api-staging.codenica.dev/api} FIREBASE_API_REWRITE_MODE=${FIREBASE_API_REWRITE_MODE:-none} bash scripts/deploy-firebase-hosting.sh",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "pnpm -r test",
    "test:watch": "pnpm --filter @duel-log/web test:watch",
    "clean": "pnpm -r clean"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild"],
    "overrides": {
      "esbuild": ">=0.25.0"
    }
  },
  "dependencies": {
    "hono": "^4.12.7",
    "lucide-react": "^0.562.0",
    "postgres": "^3.4.8",
    "zod": "^3.25.76"
  }
}
