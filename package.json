{
  "name": "duel-log-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @duel-log/web --filter @duel-log/api --parallel dev",
    "supabase:start": "npx supabase start",
    "supabase:stop": "npx supabase stop",
    "supabase:reset": "npx supabase db reset",
    "staging:pull": "npx vercel pull --yes --environment=preview --git-branch=staging",
    "staging:build": "pnpm firebase:env:staging && pnpm --filter @duel-log/shared build && pnpm --filter @duel-log/web build",
    "staging:deploy": "pnpm cloudrun:deploy-api:staging && pnpm firebase:deploy:web:staging",
    "preview:pull": "npx vercel pull --yes --environment=preview",
    "preview:build": "npx vercel pull --yes --environment=preview && npx vercel build",
    "preview:deploy": "npx vercel pull --yes --environment=preview && npx vercel build && npx vercel deploy --prebuilt",
    "production:pull": "npx vercel pull --yes --environment=production",
    "production:build": "npx vercel pull --yes --environment=production && npx vercel build --prod",
    "production:deploy": "npx vercel pull --yes --environment=production && npx vercel build --prod && npx vercel deploy --prebuilt --prod",
    "build": "pnpm -r build",
    "cloudrun:env": "node scripts/generate-cloudrun-api-env.mjs",
    "cloudrun:env:staging": "node scripts/generate-cloudrun-api-env.mjs --input .vercel/.env.preview.local --output .cloudrun/api.staging.env.yaml",
    "cloudrun:build-api": "pnpm --filter @duel-log/shared build && pnpm --filter @duel-log/api build:server",
    "cloudrun:deploy-api": "bash scripts/deploy-cloudrun-api.sh",
    "cloudrun:deploy-api:staging": "CLOUD_RUN_ENV_INPUT=${CLOUD_RUN_ENV_INPUT:-.vercel/.env.preview.local} CLOUD_RUN_ENV_FILE=${CLOUD_RUN_ENV_FILE:-.cloudrun/api.staging.env.yaml} CLOUD_RUN_SERVICE=${CLOUD_RUN_SERVICE:-duel-log-api-staging} bash scripts/deploy-cloudrun-api.sh",
    "firebase:env": "node scripts/generate-firebase-hosting-env.mjs",
    "firebase:env:staging": "node scripts/generate-firebase-hosting-env.mjs --input .vercel/.env.preview.local --output .firebase/hosting.staging.env --primary-web-url https://duel-log-staging.web.app --legacy-web-hosts ''",
    "firebase:deploy:web": "bash scripts/deploy-firebase-hosting.sh",
    "firebase:deploy:web:staging": "FIREBASE_WEB_ENV_INPUT=${FIREBASE_WEB_ENV_INPUT:-.vercel/.env.preview.local} FIREBASE_WEB_ENV_FILE=${FIREBASE_WEB_ENV_FILE:-.firebase/hosting.staging.env} FIREBASE_HOSTING_SITE=${FIREBASE_HOSTING_SITE:-duel-log-staging} FIREBASE_WEB_PRIMARY_URL=${FIREBASE_WEB_PRIMARY_URL:-https://duel-log-staging.web.app} CLOUD_RUN_SERVICE=${CLOUD_RUN_SERVICE:-duel-log-api-staging} bash scripts/deploy-firebase-hosting.sh",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "pnpm -r test",
    "test:watch": "pnpm --filter @duel-log/web test:watch",
    "clean": "pnpm -r clean"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild"],
    "overrides": {
      "esbuild": ">=0.25.0"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.91.0",
    "hono": "^4.12.7",
    "lucide-react": "^0.562.0",
    "postgres": "^3.4.8",
    "zod": "^3.25.76"
  }
}
