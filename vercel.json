{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/",
      "destination": "https://duel-log.codenica.dev/",
      "permanent": true
    },
    {
      "source": "/api/:path*",
      "destination": "https://api.duel-log.codenica.dev/api/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "destination": "https://duel-log.codenica.dev/:path*",
      "permanent": true
    }
  ]
}
