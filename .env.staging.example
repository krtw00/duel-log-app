# Staging environment
# This project uses Vercel Preview for staging, with `staging` as the staging branch.

DATABASE_URL=postgresql://app:password@127.0.0.1:5432/duel_log_staging?sslmode=require
JWT_SECRET=replace-with-shared-secret
AUTH_CALLBACK_URL=https://api-staging.example.com/api/auth/oauth/callback
WEB_URL=https://staging.example.com
VITE_API_BASE_URL=https://api-staging.example.com/api

# Optional
OBS_TOKEN_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
VITE_MAINTENANCE_BYPASS_KEY=
