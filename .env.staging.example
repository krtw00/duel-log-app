# Staging environment
# This project uses Vercel Preview for staging, with `staging` as the staging branch.
# Use a dedicated Supabase project instead of production.

SUPABASE_URL=https://your-staging-project.supabase.co
VITE_SUPABASE_URL=https://your-staging-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-staging-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-staging-secret-key
DATABASE_URL=postgresql://postgres:password@db.your-staging-project.supabase.co:5432/postgres?sslmode=require

# Optional
OBS_TOKEN_SECRET=
SUPABASE_JWT_SECRET=
VITE_MAINTENANCE_BYPASS_KEY=
