# Vercel Preview / staging-like environment
# `develop` branch should use a separate Supabase project from production.

SUPABASE_URL=https://your-preview-project.supabase.co
VITE_SUPABASE_URL=https://your-preview-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-preview-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-preview-service-role-key
DATABASE_URL=postgresql://postgres:password@db.your-preview-project.supabase.co:5432/postgres?sslmode=require

# Optional
OBS_TOKEN_SECRET=
SUPABASE_JWT_SECRET=
VITE_MAINTENANCE_BYPASS_KEY=
